---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
		<h1>🚀 Welcome to QCCBot Cloud Phone</h1>
<p>
  The next generation cloud phone platform built for overseas and cross-border operations.
  Manage hundreds of cloud phones at scale — with proxy IP, automation scripts, and remote control.
</p>

<h2>🛠 Our Products</h2>
<p>
  <strong>QCCBot</strong> — Cloud phone creation, batch management, proxy IP configuration, automation scripts, and remote control. Our core product for overseas operators.
</p>
<p>
  <strong>BashClaw</strong> — A CLI tool built on QCCBot. One-click deployment to cloud servers, batch operations, and remote cloud phone control for power users.
</p>
<p>
  <strong>Ainnc</strong> — A cross-border marketing tool built on QCCBot. Batch social media account management including TikTok, bulk video publishing, designed for overseas e-commerce.
</p>

<h2>📖 Latest from the Blog</h2>
<p>
  Check out our <a href="/blog">blog</a> for product updates, tutorials, and industry insights on cloud phone technology and overseas operations.
</p>
		</main>
		<Footer />
	</body>
</html>
